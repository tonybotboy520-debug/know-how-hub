{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm ci --prefix FrontEnd",
  "buildCommand": "npm run build --prefix FrontEnd",
  "outputDirectory": "FrontEnd/dist",
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
